generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                    String                 @id @default(uuid())
  name                  String
  slug                  String                 @unique
  plan                  PlanType               @default(FREE)
  stripeCustomerId      String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  featureFlags          Json?
  agents                Agent[]
  agentConversations    AgentConversation[]
  audiences             Audience[]
  audienceContacts      AudienceContact[]
  campaigns             Campaign[]
  companies             Company[]
  contacts              Contact[]
  enrichmentTasks       EnrichmentTask[]
  journeys              Journey[]
  journeyExecutions     JourneyExecution[]
  knowledgeBases        KnowledgeBase[]
  leadForms             LeadForm[]
  leadFormSubmissions   LeadFormSubmission[]
  metaWebhookMappings   MetaWebhookMapping[]
  pipelines             Pipeline[]
  prospects             Prospect[]
  prospectTaskEvents    ProspectTaskEvent[]
  researchTasks         ResearchTask[]
  sequenceRuns          SequenceRun[]
  stageMessageTemplates StageMessageTemplate[]
  stageRules            StageRule[]
  stageRuleRuns         StageRuleRun[]
  subscriptions         Subscription[]
  users                 User[]
  whatsappAccounts      WhatsAppAccount[]
  whatsappEvents        WhatsAppEvent[]
}

model User {
  id             String         @id @default(uuid())
  email          String
  password       String
  name           String
  role           UserRole
  tenantId       String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  assignedCards  Card[]
  cardActivities CardActivity[]
  tenant         Tenant         @relation(fields: [tenantId], references: [id])

  @@unique([email, tenantId])
}

model Pipeline {
  id                    String               @id @default(uuid())
  name                  String
  tenantId              String
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  campaignId            String?              @unique
  whatsAppAccountId     String?              @unique
  whatsAppInboundStageId String?
  metaWebhookMappings   MetaWebhookMapping[]
  campaign              Campaign?            @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  tenant                Tenant               @relation(fields: [tenantId], references: [id])
  stages                Stage[]
  whatsAppAccount       WhatsAppAccount?     @relation("PipelineWhatsAppAccount", fields: [whatsAppAccountId], references: [id], onDelete: SetNull)
  whatsAppInboundStage  Stage?               @relation("PipelineInboundStage", fields: [whatsAppInboundStageId], references: [id], onDelete: SetNull)

  @@index([tenantId, whatsAppAccountId])
}

model Stage {
  id                     String                 @id @default(uuid())
  name                   String
  order                  Int
  pipelineId             String
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  classificationCriteria String?
  agents                 Agent[]
  cards                  Card[]
  inboundForPipelines    Pipeline[]             @relation("PipelineInboundStage")
  leadForms              LeadForm[]
  metaWebhookMappings    MetaWebhookMapping[]
  pipeline               Pipeline               @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  messageTemplates       StageMessageTemplate[]
  stageRule              StageRule?
}

model Card {
  id                  String               @id @default(uuid())
  title               String
  stageId             String
  contactId           String?
  assigneeId          String?
  customFields        Json?
  position            Int
  tenantId            String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  agentConversations  AgentConversation[]
  assignee            User?                @relation(fields: [assigneeId], references: [id])
  contact             Contact?             @relation(fields: [contactId], references: [id])
  stage               Stage                @relation(fields: [stageId], references: [id], onDelete: Cascade)
  activities          CardActivity[]
  leadFormSubmissions LeadFormSubmission[]
  metaLeadIngestions  MetaLeadIngestion[]
  sequenceRuns        SequenceRun[]
  stageRuleRuns       StageRuleRun[]
}

model CardActivity {
  id           String   @id @default(uuid())
  cardId       String
  type         String
  content      String
  createdAt    DateTime @default(now())
  actorId      String?
  channel      String?
  templateName String?
  metadata     Json?
  actor        User?    @relation(fields: [actorId], references: [id])
  card         Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

model StageMessageTemplate {
  id        String          @id @default(uuid())
  stageId   String
  name      String
  channel   CampaignChannel
  subject   String?
  body      String
  tenantId  String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  stage     Stage           @relation(fields: [stageId], references: [id], onDelete: Cascade)
  tenant    Tenant          @relation(fields: [tenantId], references: [id])
  ruleSteps StageRuleStep[]

  @@index([stageId])
  @@index([tenantId, stageId])
}

model Contact {
  id                  String               @id @default(uuid())
  name                String
  phone               String?
  email               String?
  tags                String[]
  companyId           String?
  tenantId            String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  position            String?
  agentConversations  AgentConversation[]
  audienceContacts    AudienceContact[]
  cards               Card[]
  company             Company?             @relation(fields: [companyId], references: [id])
  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  leadFormSubmissions LeadFormSubmission[]
  prospectsConverted  Prospect[]
  sequenceRuns        SequenceRun[]
  whatsappEvents      WhatsAppEvent[]
  messages            WhatsAppMessage[]
}

model Company {
  id        String    @id @default(uuid())
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  industry  String?
  tenantId  String
  website   String?
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  contacts  Contact[]
}

model Audience {
  id               String            @id @default(uuid())
  name             String
  description      String?
  kind             AudienceKind      @default(DYNAMIC)
  filters          Json?
  tenantId         String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  audienceContacts AudienceContact[]
  campaigns        Campaign[]
  sequenceRuns     SequenceRun[]

  @@index([tenantId, updatedAt])
}

model AudienceContact {
  id         String   @id @default(uuid())
  audienceId String
  contactId  String
  tenantId   String
  createdAt  DateTime @default(now())
  audience   Audience @relation(fields: [audienceId], references: [id], onDelete: Cascade)
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tenant     Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([audienceId, contactId])
  @@index([tenantId, audienceId])
  @@index([tenantId, contactId])
}

model Campaign {
  id              String          @id @default(uuid())
  name            String
  description     String?
  channel         CampaignChannel @default(WHATSAPP)
  status          CampaignStatus  @default(DRAFT)
  messageTemplate String?
  launchAt        DateTime?
  audienceId      String?
  tenantId        String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  audience        Audience?       @relation(fields: [audienceId], references: [id])
  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  steps           CampaignStep[]
  pipeline        Pipeline?
  sequenceRuns    SequenceRun[]

  @@index([tenantId, updatedAt])
  @@index([tenantId, status])
}

model CampaignStep {
  id              String            @id @default(uuid())
  campaignId      String
  order           Int
  channel         CampaignChannel   @default(WHATSAPP)
  delayAmount     Int               @default(0)
  delayUnit       CampaignDelayUnit @default(HOURS)
  messageTemplate String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  campaign        Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, order])
  @@index([campaignId, order])
}

model SequenceRun {
  id               String            @id @default(uuid())
  tenantId         String
  campaignId       String
  audienceId       String?
  contactId        String
  cardId           String?
  status           SequenceRunStatus @default(PENDING)
  triggerSource    String
  startedAt        DateTime?
  completedAt      DateTime?
  lastError        String?
  nextRunAt        DateTime?
  currentStepIndex Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  audience         Audience?         @relation(fields: [audienceId], references: [id])
  campaign         Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  card             Card?             @relation(fields: [cardId], references: [id], onDelete: Cascade)
  contact          Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  steps            SequenceRunStep[]

  @@index([tenantId, status, nextRunAt])
  @@index([campaignId, contactId, createdAt])
}

model SequenceRunStep {
  id                 String                @id @default(uuid())
  runId              String
  tenantId           String
  order              Int
  channel            CampaignChannel
  delayAmount        Int                   @default(0)
  delayUnit          CampaignDelayUnit
  messageTemplate    String
  status             SequenceRunStepStatus @default(PENDING)
  scheduledFor       DateTime
  startedAt          DateTime?
  completedAt        DateTime?
  attempts           Int                   @default(0)
  externalMessageId  String?
  deliveryMode       String?
  deliveryError      String?
  lastError          String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  deadLetterReason   String?
  deadLetteredAt     DateTime?
  manualRequeueCount Int                   @default(0)
  manuallyRequeuedAt DateTime?
  run                SequenceRun           @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, order])
  @@index([tenantId, status, scheduledFor])
  @@index([runId, scheduledFor])
}

model Agent {
  id              String              @id @default(uuid())
  name            String
  systemPrompt    String
  isActive        Boolean             @default(true)
  stageId         String?
  knowledgeBaseId String?
  tenantId        String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  profile         Json?
  knowledgeBase   KnowledgeBase?      @relation(fields: [knowledgeBaseId], references: [id], onDelete: SetNull)
  stage           Stage?              @relation(fields: [stageId], references: [id], onDelete: Cascade)
  tenant          Tenant              @relation(fields: [tenantId], references: [id])
  conversations   AgentConversation[]
}

model AgentConversation {
  id            String                  @id @default(uuid())
  agentId       String
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  cardId        String?
  contactId     String
  lastMessageAt DateTime?
  status        AgentConversationStatus @default(OPEN)
  summary       String?
  tenantId      String
  agent         Agent                   @relation(fields: [agentId], references: [id], onDelete: Cascade)
  card          Card?                   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  contact       Contact                 @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tenant        Tenant                  @relation(fields: [tenantId], references: [id])
  messages      AgentMessage[]

  @@index([tenantId, contactId])
  @@index([tenantId, agentId])
}

model AgentMessage {
  id                String            @id @default(uuid())
  conversationId    String
  role              AgentMessageRole
  content           String
  whatsAppMessageId String?           @unique
  createdAt         DateTime          @default(now())
  metadata          Json?
  conversation      AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  whatsAppMessage   WhatsAppMessage?  @relation(fields: [whatsAppMessageId], references: [id], onDelete: SetNull)
}

model Journey {
  id         String             @id @default(uuid())
  name       String
  isActive   Boolean            @default(false)
  nodes      Json
  edges      Json
  tenantId   String
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  tenant     Tenant             @relation(fields: [tenantId], references: [id])
  executions JourneyExecution[]
}

model JourneyExecution {
  id             String                 @id @default(uuid())
  journeyId      String
  tenantId       String
  triggerSource  String
  triggerPayload Json?
  contactId      String?
  cardId         String?
  status         JourneyExecutionStatus @default(PENDING)
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  journey        Journey                @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  tenant         Tenant                 @relation(fields: [tenantId], references: [id])
  jobs           JourneyExecutionJob[]
  logs           JourneyExecutionLog[]

  @@index([tenantId, journeyId, createdAt])
}

model JourneyExecutionJob {
  id             String                    @id @default(uuid())
  executionId    String
  tenantId       String
  nodeId         String
  nodeLabel      String?
  nodeKind       String
  actionType     String?
  delayInSeconds Int                       @default(0)
  status         JourneyExecutionJobStatus @default(PENDING)
  scheduledFor   DateTime
  startedAt      DateTime?
  completedAt    DateTime?
  attempts       Int                       @default(0)
  lastError      String?
  details        Json?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  execution      JourneyExecution          @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@unique([executionId, nodeId])
  @@index([status, scheduledFor])
  @@index([executionId, createdAt])
  @@index([tenantId, status, scheduledFor])
}

model JourneyExecutionLog {
  id          String                   @id @default(uuid())
  executionId String
  level       JourneyExecutionLogLevel @default(INFO)
  nodeId      String?
  nodeLabel   String?
  message     String
  details     Json?
  createdAt   DateTime                 @default(now())
  execution   JourneyExecution         @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId, createdAt])
}

model LeadForm {
  id                String               @id @default(uuid())
  name              String
  slug              String
  headline          String?
  description       String?
  submitButtonLabel String?
  successTitle      String?
  successMessage    String?
  isActive          Boolean              @default(true)
  fields            Json
  stageId           String
  tenantId          String
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  stage             Stage                @relation(fields: [stageId], references: [id], onDelete: Cascade)
  tenant            Tenant               @relation(fields: [tenantId], references: [id])
  submissions       LeadFormSubmission[]

  @@unique([tenantId, slug])
  @@index([tenantId, stageId])
}

model LeadFormSubmission {
  id        String   @id @default(uuid())
  formId    String?
  tenantId  String
  contactId String?
  cardId    String?
  payload   Json
  createdAt DateTime @default(now())
  card      Card?    @relation(fields: [cardId], references: [id], onDelete: Cascade)
  contact   Contact? @relation(fields: [contactId], references: [id])
  form      LeadForm? @relation(fields: [formId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, formId])
  @@index([tenantId, createdAt])
}

model KnowledgeBase {
  id        String   @id @default(uuid())
  name      String
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  content   String?
  summary   String?
  agents    Agent[]
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

model WhatsAppAccount {
  id            String          @id @default(uuid())
  phoneNumberId String?
  wabaId        String?
  tenantId      String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  accessToken   String?
  phoneNumber   String?
  status        WhatsAppStatus  @default(DISCONNECTED)
  provider      String          @default("meta_cloud")
  instanceName  String?
  apiKey        String?
  webhookUrl    String?
  tenant        Tenant          @relation(fields: [tenantId], references: [id])
  events        WhatsAppEvent[]
  pipeline      Pipeline?       @relation("PipelineWhatsAppAccount")
}

model WhatsAppEvent {
  id         String            @id @default(uuid())
  tenantId   String
  accountId  String?
  contactId  String?
  kind       WhatsAppEventKind
  status     MessageStatus?
  externalId String?
  source     String
  payload    Json?
  error      String?
  createdAt  DateTime          @default(now())
  account    WhatsAppAccount?  @relation(fields: [accountId], references: [id])
  contact    Contact?          @relation(fields: [contactId], references: [id])
  tenant     Tenant            @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, kind, createdAt])
  @@index([tenantId, externalId])
}

model WhatsAppMessage {
  id           String           @id @default(uuid())
  contactId    String
  content      String
  createdAt    DateTime         @default(now())
  direction    MessageDirection @default(INBOUND)
  externalId   String?
  status       MessageStatus    @default(SENT)
  agentMessage AgentMessage?
  contact      Contact          @relation(fields: [contactId], references: [id])
}

model Prospect {
  id                 String              @id @default(uuid())
  tenantId           String
  name               String
  companyName        String?
  email              String?
  phone              String?
  title              String?
  source             String              @default("manual")
  status             ProspectStatus      @default(NEW)
  score              Int                 @default(0)
  metadata           Json?
  optedOutAt         DateTime?
  optedOutReason     String?
  convertedContactId String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  enrichmentTasks    EnrichmentTask[]
  convertedContact   Contact?            @relation(fields: [convertedContactId], references: [id])
  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  taskEvents         ProspectTaskEvent[]
  researchTasks      ResearchTask[]

  @@index([tenantId, status, updatedAt])
  @@index([tenantId, source, updatedAt])
  @@index([tenantId, email])
  @@index([tenantId, phone])
}

model ResearchTask {
  id          String             @id @default(uuid())
  tenantId    String
  prospectId  String
  status      ProspectTaskStatus @default(PENDING)
  prompt      String?
  result      Json?
  lastError   String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  prospect    Prospect           @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  tenant      Tenant             @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status, createdAt])
  @@index([prospectId, createdAt])
}

model EnrichmentTask {
  id          String             @id @default(uuid())
  tenantId    String
  prospectId  String
  status      ProspectTaskStatus @default(PENDING)
  prompt      String?
  result      Json?
  lastError   String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  prospect    Prospect           @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  tenant      Tenant             @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status, createdAt])
  @@index([prospectId, createdAt])
}

model ProspectTaskEvent {
  id         String                @id @default(uuid())
  tenantId   String
  prospectId String?
  taskType   ProspectTaskType
  eventType  ProspectTaskEventType
  taskId     String
  title      String
  payload    Json?
  createdAt  DateTime              @default(now())
  prospect   Prospect?             @relation(fields: [prospectId], references: [id])
  tenant     Tenant                @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, prospectId, createdAt])
  @@index([tenantId, taskType, eventType, createdAt])
}

model Subscription {
  id        String   @id @default(uuid())
  tenantId  String
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

model StageRule {
  id        String          @id @default(uuid())
  stageId   String          @unique
  tenantId  String
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  stage     Stage           @relation(fields: [stageId], references: [id], onDelete: Cascade)
  tenant    Tenant          @relation(fields: [tenantId], references: [id])
  runs      StageRuleRun[]
  steps     StageRuleStep[]

  @@index([tenantId, stageId])
}

model StageRuleStep {
  id                String               @id @default(uuid())
  ruleId            String
  order             Int
  dayOffset         Int
  channel           CampaignChannel
  messageTemplateId String
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  runSteps          StageRuleRunStep[]
  messageTemplate   StageMessageTemplate @relation(fields: [messageTemplateId], references: [id], onDelete: Cascade)
  rule              StageRule            @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([ruleId, order])
  @@index([ruleId, order])
}

model StageRuleRun {
  id            String             @id @default(uuid())
  ruleId        String
  cardId        String
  tenantId      String
  status        StageRuleRunStatus @default(PENDING)
  triggerSource String
  startedAt     DateTime?
  completedAt   DateTime?
  pausedAt      DateTime?
  canceledAt    DateTime?
  lastError     String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  card          Card               @relation(fields: [cardId], references: [id], onDelete: Cascade)
  rule          StageRule          @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  tenant        Tenant             @relation(fields: [tenantId], references: [id])
  steps         StageRuleRunStep[]

  @@index([tenantId, status])
  @@index([cardId, status])
}

model StageRuleRunStep {
  id                String                 @id @default(uuid())
  runId             String
  tenantId          String
  ruleStepId        String
  order             Int
  channel           CampaignChannel
  scheduledFor      DateTime
  status            StageRuleRunStepStatus @default(PENDING)
  startedAt         DateTime?
  completedAt       DateTime?
  attempts          Int                    @default(0)
  lastError         String?
  externalMessageId String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  ruleStep          StageRuleStep          @relation(fields: [ruleStepId], references: [id])
  run               StageRuleRun           @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, order])
  @@index([tenantId, status, scheduledFor])
}

model MetaWebhookMapping {
  id              String   @id @default(uuid())
  tenantId        String
  metaFormId      String?  // nullable for page-level catch-all mappings
  pageId          String?  // page-level mapping for organic leads
  pipelineId      String
  stageId         String
  verifyToken     String
  pageAccessToken String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  pipeline        Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  stage           Stage    @relation(fields: [stageId], references: [id], onDelete: Cascade)
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([pageId])
  @@index([metaFormId])
  @@unique([pageId, metaFormId])
  @@unique([verifyToken])
}

model MetaLeadIngestion {
  id         String   @id @default(uuid())
  tenantId   String
  metaLeadId String   @unique
  cardId     String?
  createdAt  DateTime @default(now())
  card       Card?    @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

enum WhatsAppStatus {
  CONNECTED
  DISCONNECTED
  QR_READY
  ERROR
}

enum WhatsAppEventKind {
  WEBHOOK_MESSAGE
  WEBHOOK_STATUS
  OUTBOUND_SEND
  WEBHOOK_CHALLENGE
  WEBHOOK_SIMULATOR
}

enum ProspectStatus {
  NEW
  RESEARCHING
  READY
  CONTACTED
  REPLIED
  OPTED_OUT
  CONVERTED
  INVALID
}

enum ProspectTaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
}

enum ProspectTaskType {
  RESEARCH
  ENRICHMENT
}

enum ProspectTaskEventType {
  ENQUEUED
  STARTED
  COMPLETED
  FAILED
  SKIPPED
  REQUEUED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

enum AgentConversationStatus {
  OPEN
  HANDOFF_REQUIRED
  CLOSED
}

enum AgentMessageRole {
  USER
  AGENT
  HUMAN
  SYSTEM
}

enum JourneyExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
}

enum JourneyExecutionLogLevel {
  INFO
  WARN
  ERROR
}

enum JourneyExecutionJobStatus {
  PENDING
  RUNNING
  COMPLETED
