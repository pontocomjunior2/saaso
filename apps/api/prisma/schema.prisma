// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id               String   @id @default(uuid())
  name             String
  slug             String   @unique
  plan             PlanType @default(FREE)
  stripeCustomerId String?
  featureFlags     Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users            User[]
  pipelines        Pipeline[]
  contacts         Contact[]
  companies        Company[]
  agents           Agent[]
  knowledgeBases   KnowledgeBase[]
  whatsappAccounts WhatsAppAccount[]
  whatsappEvents   WhatsAppEvent[]
  subscriptions    Subscription[]
  journeys         Journey[]
  journeyExecutions JourneyExecution[]
  agentConversations AgentConversation[]
  leadForms        LeadForm[]
  leadFormSubmissions LeadFormSubmission[]
  audiences        Audience[]
  audienceContacts AudienceContact[]
  campaigns        Campaign[]
  sequenceRuns     SequenceRun[]
  prospects        Prospect[]
  researchTasks    ResearchTask[]
  enrichmentTasks  EnrichmentTask[]
  prospectTaskEvents ProspectTaskEvent[]
}

model User {
  id        String   @id @default(uuid())
  email     String
  password  String
  name      String
  role      UserRole
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedCards Card[]

  @@unique([email, tenantId])
}

model Pipeline {
  id        String   @id @default(uuid())
  name      String
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  stages    Stage[]
  campaignId String?  @unique
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Stage {
  id         String   @id @default(uuid())
  name       String
  order      Int
  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  cards      Card[]
  agents     Agent[]
  leadForms  LeadForm[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Card {
  id           String   @id @default(uuid())
  title        String
  stageId      String
  stage        Stage    @relation(fields: [stageId], references: [id], onDelete: Cascade)
  contactId    String?
  contact      Contact? @relation(fields: [contactId], references: [id])
  assigneeId   String?
  assignee     User?    @relation(fields: [assigneeId], references: [id])
  customFields Json?
  position     Int
  tenantId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  activities CardActivity[]
  agentConversations AgentConversation[]
  leadFormSubmissions LeadFormSubmission[]
  sequenceRuns SequenceRun[]
}

model CardActivity {
  id        String   @id @default(uuid())
  cardId    String
  card      Card     @relation(fields: [cardId], references: [id])
  type      String
  content   String
  createdAt DateTime @default(now())
}

model Contact {
  id        String            @id @default(uuid())
  name      String
  phone     String?
  email     String?
  position  String?
  tags      String[]
  companyId String?
  company   Company?          @relation(fields: [companyId], references: [id])
  tenantId  String
  tenant    Tenant            @relation(fields: [tenantId], references: [id])
  cards     Card[]
  messages  WhatsAppMessage[]
  audienceContacts AudienceContact[]
  agentConversations AgentConversation[]
  leadFormSubmissions LeadFormSubmission[]
  sequenceRuns SequenceRun[]
  whatsappEvents WhatsAppEvent[]
  prospectsConverted Prospect[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model Company {
  id        String    @id @default(uuid())
  name      String
  industry  String?
  website   String?
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  contacts  Contact[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Audience {
  id          String       @id @default(uuid())
  name        String
  description String?
  kind        AudienceKind @default(DYNAMIC)
  filters     Json?
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  audienceContacts AudienceContact[]
  campaigns   Campaign[]
  sequenceRuns SequenceRun[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([tenantId, updatedAt])
}

model AudienceContact {
  id         String   @id @default(uuid())
  audienceId String
  audience   Audience @relation(fields: [audienceId], references: [id], onDelete: Cascade)
  contactId  String
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([audienceId, contactId])
  @@index([tenantId, audienceId])
  @@index([tenantId, contactId])
}

model Campaign {
  id              String          @id @default(uuid())
  name            String
  description     String?
  channel         CampaignChannel @default(WHATSAPP)
  status          CampaignStatus  @default(DRAFT)
  messageTemplate String?
  launchAt        DateTime?
  audienceId      String?
  audience        Audience?       @relation(fields: [audienceId], references: [id], onDelete: SetNull)
  tenantId        String
  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  steps           CampaignStep[]
  sequenceRuns    SequenceRun[]
  pipeline        Pipeline?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([tenantId, updatedAt])
  @@index([tenantId, status])
}

model CampaignStep {
  id              String            @id @default(uuid())
  campaignId      String
  campaign        Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  order           Int
  channel         CampaignChannel   @default(WHATSAPP)
  delayAmount     Int               @default(0)
  delayUnit       CampaignDelayUnit @default(HOURS)
  messageTemplate String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([campaignId, order])
  @@index([campaignId, order])
}

model SequenceRun {
  id           String            @id @default(uuid())
  tenantId     String
  tenant       Tenant            @relation(fields: [tenantId], references: [id])
  campaignId   String
  campaign     Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  audienceId   String?
  audience     Audience?         @relation(fields: [audienceId], references: [id], onDelete: SetNull)
  contactId    String
  contact      Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)
  cardId       String?
  card         Card?             @relation(fields: [cardId], references: [id], onDelete: SetNull)
  status       SequenceRunStatus @default(PENDING)
  triggerSource String
  startedAt    DateTime?
  completedAt  DateTime?
  lastError    String?
  nextRunAt    DateTime?
  currentStepIndex Int            @default(0)
  steps        SequenceRunStep[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([tenantId, status, nextRunAt])
  @@index([campaignId, contactId, createdAt])
}

model SequenceRunStep {
  id             String                @id @default(uuid())
  runId          String
  run            SequenceRun           @relation(fields: [runId], references: [id], onDelete: Cascade)
  tenantId       String
  order          Int
  channel        CampaignChannel
  delayAmount    Int                   @default(0)
  delayUnit      CampaignDelayUnit
  messageTemplate String
  status         SequenceRunStepStatus @default(PENDING)
  scheduledFor   DateTime
  startedAt      DateTime?
  completedAt    DateTime?
  attempts       Int                   @default(0)
  externalMessageId String?
  deliveryMode   String?
  deliveryError  String?
  lastError      String?
  deadLetteredAt DateTime?
  deadLetterReason String?
  manuallyRequeuedAt DateTime?
  manualRequeueCount Int               @default(0)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@unique([runId, order])
  @@index([tenantId, status, scheduledFor])
  @@index([runId, scheduledFor])
}

model Agent {
  id              String              @id @default(uuid())
  name            String
  systemPrompt    String
  profile         Json?
  isActive        Boolean             @default(true)
  stageId         String?
  stage           Stage?              @relation(fields: [stageId], references: [id], onDelete: Cascade)
  knowledgeBaseId String?
  knowledgeBase   KnowledgeBase?      @relation(fields: [knowledgeBaseId], references: [id])
  tenantId        String
  tenant          Tenant              @relation(fields: [tenantId], references: [id])
  conversations   AgentConversation[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

model AgentConversation {
  id            String                  @id @default(uuid())
  agentId       String
  agent         Agent                   @relation(fields: [agentId], references: [id])
  contactId     String
  contact       Contact                 @relation(fields: [contactId], references: [id])
  cardId        String?
  card          Card?                   @relation(fields: [cardId], references: [id])
  tenantId      String
  tenant        Tenant                  @relation(fields: [tenantId], references: [id])
  status        AgentConversationStatus @default(OPEN)
  summary       String?
  lastMessageAt DateTime?
  messages      AgentMessage[]
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  @@index([tenantId, contactId])
  @@index([tenantId, agentId])
}

model AgentMessage {
  id                String           @id @default(uuid())
  conversationId    String
  conversation      AgentConversation @relation(fields: [conversationId], references: [id])
  role              AgentMessageRole
  content           String
  whatsAppMessageId String?          @unique
  whatsAppMessage   WhatsAppMessage? @relation(fields: [whatsAppMessageId], references: [id])
  createdAt         DateTime         @default(now())
}

model Journey {
  id         String             @id @default(uuid())
  name       String
  isActive   Boolean            @default(false)
  nodes      Json               // ReactFlow Nodes (triggers, actions, conditions)
  edges      Json               // ReactFlow Edges (conexões entre nodes)
  tenantId   String
  tenant     Tenant             @relation(fields: [tenantId], references: [id])
  executions JourneyExecution[]
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
}

model JourneyExecution {
  id            String                 @id @default(uuid())
  journeyId     String
  journey       Journey                @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  tenantId      String
  tenant        Tenant                 @relation(fields: [tenantId], references: [id])
  triggerSource String
  triggerPayload Json?
  contactId     String?
  cardId        String?
  status        JourneyExecutionStatus @default(PENDING)
  startedAt     DateTime?
  completedAt   DateTime?
  logs          JourneyExecutionLog[]
  jobs          JourneyExecutionJob[]
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@index([tenantId, journeyId, createdAt])
}

model JourneyExecutionJob {
  id            String                    @id @default(uuid())
  executionId   String
  execution     JourneyExecution          @relation(fields: [executionId], references: [id], onDelete: Cascade)
  tenantId      String
  nodeId        String
  nodeLabel     String?
  nodeKind      String
  actionType    String?
  delayInSeconds Int                      @default(0)
  status        JourneyExecutionJobStatus @default(PENDING)
  scheduledFor  DateTime
  startedAt     DateTime?
  completedAt   DateTime?
  attempts      Int                       @default(0)
  lastError     String?
  details       Json?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  @@index([status, scheduledFor])
  @@index([executionId, createdAt])
  @@index([tenantId, status, scheduledFor])
  @@unique([executionId, nodeId])
}

model JourneyExecutionLog {
  id         String                   @id @default(uuid())
  executionId String
  execution  JourneyExecution         @relation(fields: [executionId], references: [id], onDelete: Cascade)
  level      JourneyExecutionLogLevel @default(INFO)
  nodeId     String?
  nodeLabel  String?
  message    String
  details    Json?
  createdAt  DateTime                 @default(now())

  @@index([executionId, createdAt])
}

model LeadForm {
  id                String               @id @default(uuid())
  name              String
  slug              String
  headline          String?
  description       String?
  submitButtonLabel String?
  successTitle      String?
  successMessage    String?
  isActive          Boolean              @default(true)
  fields            Json
  stageId           String
  stage             Stage                @relation(fields: [stageId], references: [id], onDelete: Cascade)
  tenantId          String
  tenant            Tenant               @relation(fields: [tenantId], references: [id])
  submissions       LeadFormSubmission[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId, stageId])
}

model LeadFormSubmission {
  id        String   @id @default(uuid())
  formId    String
  form      LeadForm @relation(fields: [formId], references: [id])
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])
  cardId    String?
  card      Card?    @relation(fields: [cardId], references: [id])
  payload   Json
  createdAt DateTime @default(now())

  @@index([tenantId, formId])
  @@index([tenantId, createdAt])
}

model KnowledgeBase {
  id        String   @id @default(uuid())
  name      String
  summary   String?
  content   String?
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  agents    Agent[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WhatsAppAccount {
  id            String               @id @default(uuid())
  phoneNumber   String?
  phoneNumberId String?
  wabaId        String?
  accessToken   String?
  status        WhatsAppStatus       @default(DISCONNECTED)
  tenantId      String
  tenant        Tenant               @relation(fields: [tenantId], references: [id])
  events        WhatsAppEvent[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
}

model WhatsAppEvent {
  id         String            @id @default(uuid())
  tenantId   String
  tenant     Tenant            @relation(fields: [tenantId], references: [id])
  accountId  String?
  account    WhatsAppAccount?  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  contactId  String?
  contact    Contact?          @relation(fields: [contactId], references: [id], onDelete: SetNull)
  kind       WhatsAppEventKind
  status     MessageStatus?
  externalId String?
  source     String
  payload    Json?
  error      String?
  createdAt  DateTime          @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, kind, createdAt])
  @@index([tenantId, externalId])
}

model WhatsAppMessage {
  id         String           @id @default(uuid())
  contactId  String
  contact    Contact          @relation(fields: [contactId], references: [id])
  content    String
  direction  MessageDirection @default(INBOUND)
  status     MessageStatus    @default(SENT)
  externalId String?
  agentMessage AgentMessage?
  createdAt  DateTime         @default(now())
}

model Prospect {
  id                String             @id @default(uuid())
  tenantId          String
  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  name              String
  companyName       String?
  email             String?
  phone             String?
  title             String?
  source            String             @default("manual")
  status            ProspectStatus      @default(NEW)
  score             Int                @default(0)
  metadata          Json?
  optedOutAt        DateTime?
  optedOutReason    String?
  convertedContactId String?
  convertedContact  Contact?           @relation(fields: [convertedContactId], references: [id], onDelete: SetNull)
  researchTasks     ResearchTask[]
  enrichmentTasks   EnrichmentTask[]
  taskEvents        ProspectTaskEvent[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([tenantId, status, updatedAt])
  @@index([tenantId, source, updatedAt])
  @@index([tenantId, email])
  @@index([tenantId, phone])
}

model ResearchTask {
  id            String              @id @default(uuid())
  tenantId      String
  tenant        Tenant              @relation(fields: [tenantId], references: [id])
  prospectId    String
  prospect      Prospect            @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  status        ProspectTaskStatus  @default(PENDING)
  prompt        String?
  result        Json?
  lastError     String?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([tenantId, status, createdAt])
  @@index([prospectId, createdAt])
}

model EnrichmentTask {
  id            String              @id @default(uuid())
  tenantId      String
  tenant        Tenant              @relation(fields: [tenantId], references: [id])
  prospectId    String
  prospect      Prospect            @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  status        ProspectTaskStatus  @default(PENDING)
  prompt        String?
  result        Json?
  lastError     String?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([tenantId, status, createdAt])
  @@index([prospectId, createdAt])
}

model ProspectTaskEvent {
  id         String              @id @default(uuid())
  tenantId   String
  tenant     Tenant              @relation(fields: [tenantId], references: [id])
  prospectId String?
  prospect   Prospect?           @relation(fields: [prospectId], references: [id], onDelete: SetNull)
  taskType   ProspectTaskType
  eventType  ProspectTaskEventType
  taskId     String
  title      String
  payload    Json?
  createdAt  DateTime            @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, prospectId, createdAt])
  @@index([tenantId, taskType, eventType, createdAt])
}

enum WhatsAppStatus {
  CONNECTED
  DISCONNECTED
  QR_READY
  ERROR
}

enum WhatsAppEventKind {
  WEBHOOK_MESSAGE
  WEBHOOK_STATUS
  OUTBOUND_SEND
  WEBHOOK_CHALLENGE
  WEBHOOK_SIMULATOR
}

enum ProspectStatus {
  NEW
  RESEARCHING
  READY
  CONTACTED
  REPLIED
  OPTED_OUT
  CONVERTED
  INVALID
}

enum ProspectTaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
}

enum ProspectTaskType {
  RESEARCH
  ENRICHMENT
}

enum ProspectTaskEventType {
  ENQUEUED
  STARTED
  COMPLETED
  FAILED
  SKIPPED
  REQUEUED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

enum AgentConversationStatus {
  OPEN
  HANDOFF_REQUIRED
  CLOSED
}

enum AgentMessageRole {
  USER
  AGENT
  HUMAN
  SYSTEM
}

enum JourneyExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
}

enum JourneyExecutionLogLevel {
  INFO
  WARN
  ERROR
}

enum JourneyExecutionJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
}

model Subscription {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  AGENT
}

enum PlanType {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum AudienceKind {
  DYNAMIC
  MANUAL
}

enum CampaignChannel {
  WHATSAPP
  EMAIL
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
}

enum CampaignDelayUnit {
  MINUTES
  HOURS
  DAYS
}

enum SequenceRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  PAUSED
  CANCELED
}

enum SequenceRunStepStatus {
  PENDING
  QUEUED
  RUNNING
  SENT
  FAILED
  SKIPPED
}
