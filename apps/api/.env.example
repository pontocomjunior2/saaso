CAMPAIGN_RUNTIME_POLL_MS="5000"
CAMPAIGN_RUNTIME_WORKER_CONCURRENCY="4"
JOURNEY_RUNTIME_DRIVER="bullmq"
JOURNEY_RUNTIME_POLL_MS="5000"
JOURNEY_RUNTIME_WORKER_CONCURRENCY="4"
