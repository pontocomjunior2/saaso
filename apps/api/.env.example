# DB
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/saaso?schema=public"
FRONTEND_URL="http://localhost:3000"

# Auth
JWT_SECRET="supers3cr3t"
JWT_EXPIRATION="15m"

# Application Ports
PORT=3001
WHATSAPP_WEBHOOK_VERIFY_TOKEN="saaso-dev-webhook-token"
WHATSAPP_CLOUD_API_BASE_URL="https://graph.facebook.com/v23.0"

# Email SMTP (Mailtrap sandbox: host=sandbox.smtp.mailtrap.io port=2525)
MAIL_HOST=""
MAIL_PORT="2525"
MAIL_USER=""
MAIL_PASS=""
MAIL_FROM="noreply@saaso.app"
MAIL_FROM_NAME=Saaso CRM

# Mailtrap API (opcional — para envio via API em vez de SMTP)
MAILTRAP_API_TOKEN=""
MAILTRAP_MODE=sandbox              # "sandbox" em dev, remover ou deixar vazio em prod
MAILTRAP_INBOX_ID=                 # ID da inbox sandbox (obter no painel Mailtrap)

# OpenAI
OPENAI_API_KEY=""
OPENAI_API_BASE_URL="https://api.openai.com/v1"

# Redis / Journey Runtime
REDIS_HOST="127.0.0.1"
REDIS_PORT="6379"
REDIS_DB="0"
REDIS_PASSWORD=""
